# avird-2026 — repo-root environment variables (db pipeline + local seed)
#
# db/connection.py and tools/local_db_setup.py load this file's gitignored
# sibling `.env` via dotenv. Never commit a real value.
#
# Local dev points at the avird_dev database on the native Windows
# PostgreSQL 17 instance (:5432). Use the postgres password chosen at
# install. The api service (asyncpg) and the pipeline (SQLAlchemy+psycopg)
# share the same URL value; keep the bare postgresql:// scheme — each
# consumer rewrites it for its own driver.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/avird_dev
