# apps/web — environment variables
#
# In Railway, API_URL is set as a reference variable pointing at the api
# service's PROJECT-INTERNAL hostname (the api has no public domain).
# Server-only — no NEXT_PUBLIC_ prefix; never bundled into client code.
# Routes that read API_URL must declare `export const dynamic = 'force-dynamic'`.
# See docs/conventions/stack.md for the full env-var contract.

# Base URL of the FastAPI service. Local dev default is the dev server.
# 127.0.0.1, not localhost: Node's fetch resolves localhost to ::1 on Windows
# while uvicorn binds IPv4 only, so localhost fails server-side.
API_URL=http://127.0.0.1:8000
