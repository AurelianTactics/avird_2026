# apps/api — environment variables
#
# In Railway, DATABASE_URL is injected at runtime as a reference variable
# pointing at the project's Postgres service. Never commit a real value.
# See docs/conventions/stack.md for the full env-var contract.

# Postgres connection string. For local dev, point at any reachable Postgres.
# Example local value:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/avird_dev

# Railway sets PORT automatically. Override locally if 8000 is in use.
PORT=8000

# Anthropic API key for the runtime LLM routes — the live debate routes
# (POST /incidents/{id}/debate/{turn,judge}) and the NL-query agent
# (POST /derived/query). Set in Railway on the `api` service; consumed by `api`
# only; never committed. The site renders fully WITHOUT this key — only those
# LLM routes degrade to their fallbacks (debate paused; query -> default view).
# Optional model override; defaults to the latest Claude in the agent code.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# Daily USD spend ceilings for the public LLM surfaces (rolling 24h, per-feature
# so one can't drain the other). Each route degrades gracefully over its cap.
# Defaults if unset: debate $5, NL-query $2.
# DEBATE_DAILY_BUDGET_USD=5
# DERIVED_DAILY_BUDGET_USD=2
