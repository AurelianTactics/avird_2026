# apps/api — environment variables
#
# In Railway, DATABASE_URL is injected at runtime as a reference variable
# pointing at the project's Postgres service. Never commit a real value.
# See docs/conventions/stack.md for the full env-var contract.

# Postgres connection string. For local dev, point at any reachable Postgres.
# Example local value:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/avird_dev

# Railway sets PORT automatically. Override locally if 8000 is in use.
PORT=8000

# Anthropic API key for the NL-query agent (POST /derived/query). Set in
# Railway on the `api` service; consumed by `api` only; never committed.
# The site renders fully WITHOUT this key — only the natural-language query
# path degrades to the unfiltered default-view fallback (plan KTD 4).
# Optional model override; defaults to the latest Claude in the agent code.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8
