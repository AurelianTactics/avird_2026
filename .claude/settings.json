{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(./**)",
      "Bash(ruff:*)",
      "Bash(npx prettier:*)",
      "Bash(npx --no-install prettier:*)",
      "Bash(npm run lint:*)",
      "Bash(npm test:*)",
      "Bash(npm run test:*)",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(python tools/verify_site.py:*)",
      "Bash(python tools/verify_evidence.py:*)",
      "Bash(python tools/dev_stack.py:*)",
      "Bash(python tools/local_db_setup.py:*)",
      "Bash(python db/run_pipeline.py:*)",
      "Bash(npx playwright install:*)",
      "mcp__plugin_playwright_playwright",
      "Bash(python ${CLAUDE_PROJECT_DIR}/.claude/hooks/format_on_edit.py:*)",
      "Bash(python ${CLAUDE_PROJECT_DIR}/.claude/hooks/mark_web_pending.py:*)",
      "Bash(python ${CLAUDE_PROJECT_DIR}/.claude/hooks/verify_gate.py:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/format_on_edit.py\""
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/mark_web_pending.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/verify_gate.py\""
          }
        ]
      }
    ]
  }
}
