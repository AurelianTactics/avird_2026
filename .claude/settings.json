{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(./**)",
      "Bash(ruff:*)",
      "Bash(npx prettier:*)",
      "Bash(npx --no-install prettier:*)",
      "Bash(npm run lint:*)",
      "Bash(npm test:*)",
      "Bash(npm run test:*)",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(python tools/verify_site.py:*)",
      "Bash(python ${CLAUDE_PROJECT_DIR}/.claude/hooks/format_on_edit.py:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/format_on_edit.py\""
          }
        ]
      }
    ]
  }
}
